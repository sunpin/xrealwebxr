{
  "manifest_version": 3,
  "name": "XREAL WebXR 6DoF Bridge",
  "version": "1.0.0",
  "description": "XREAL glasses WebXR Polyfill & 2D SBS Mirroring Extension",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
